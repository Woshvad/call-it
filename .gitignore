# Dependencies
node_modules
.pnpm-store

# Build outputs
dist
out
.next
build

# Turborepo cache
.turbo

# Environment files — NEVER commit real env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.prod
# Backups of env files (may contain real secrets) — NEVER commit
.env*.bak*
*.env.bak*
.env.bak*

# Foundry deploy logs (regenerable; canonical record is broadcast/run-latest.json)
deploy-*.log

# Foundry build artifacts
forge-cache
cache
out

# Rust / Cargo / Stylus build artifacts
target
Cargo.lock

# TypeScript incremental build info
*.tsbuildinfo

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea

# Logs
*.log
logs

# Test coverage
coverage
.nyc_output

# Vercel
.vercel

# Smoke test result artifacts (generated by scripts/phase-0-smoke.ts during test runs)
# The gate workflow uploads these as GitHub release assets; they do not belong in git history.
scripts/phase-0-smoke-results-*.json

# Vitest parity output (generated at runtime by parity tests; read by parity-diff script)
# These are ephemeral build artifacts — the CI workflow regenerates them before diffing.
packages/shared/.vitest-parity-output.json
packages/shared/.vitest-duplicate-hash-parity-output.json
packages/.vitest-parity-output.json
packages/.vitest-duplicate-hash-parity-output.json
