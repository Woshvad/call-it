# =============================================================================
# Call It — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env, .env.local, .env.production, or any file with real secrets.
# All signing keys live in GCP KMS (D-06). Non-signing secrets live in GCP
# Secret Manager (D-08). This file contains only placeholder values + comments.
# =============================================================================

# --- Relayer / Backend ----------------------------------------------------- #

# URL of the relayer (Fastify on Fly.io). Phase 0–6: default *.fly.dev domain.
# Phase 7: rebrand to api.callitapp.xyz (D-12).
RELAYER_URL=https://call-it-relayer.fly.dev

# HMAC secret shared between Next.js web and the relayer for internal route auth.
# Generated with: openssl rand -hex 32
RELAYER_INTERNAL_HMAC=REPLACE_ME_openssl_rand_hex_32

# --- Telegram Bot (Phase 0 OPS-07..OPS-14) --------------------------------- #

# Bot token from @BotFather. Used for P0 (critical) and P1 (informational) alerts.
TELEGRAM_BOT_TOKEN=REPLACE_ME_bot_token_from_botfather

# Telegram channel IDs (negative numbers for group/channel). D-15: two channels.
TELEGRAM_CHAT_ID_P0=REPLACE_ME_p0_channel_id
TELEGRAM_CHAT_ID_P1=REPLACE_ME_p1_channel_id

# --- Upstash Redis (D-03) -------------------------------------------------- #

# Upstash serverless Redis — BullMQ backing + paymaster daily counter + DeFiLlama cache.
# Verify BullMQ PUBSUB + blocking-command compatibility per Wave 0 research note.
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME_upstash_token

# --- Google Cloud KMS + Secret Manager (D-06, D-07, D-08, D-09) ----------- #
# D-09: Separate GCP projects per network: call-it-sepolia / call-it-mainnet.
# Signing keys NEVER leave KMS. Non-signing secrets in Secret Manager.

GCP_PROJECT_ID=call-it-sepolia
GCP_LOCATION_ID=global
GCP_KEYRING_ID=attestations

# Key versions for each of the 5 attestation signing keys (D-07).
# Bump the version number on rotation; keep old version active until all in-flight
# signatures expire.
GCP_KEY_VERSION_NFT_TWAP=1
GCP_KEY_VERSION_DEFILLAMA=1
GCP_KEY_VERSION_CEX=1
GCP_KEY_VERSION_SNAPSHOT_TALLY=1
GCP_KEY_VERSION_OAUTH_PROOF=1

# --- Observability (D-14) -------------------------------------------------- #

# Better Stack (Logtail) source token for Pino → Logtail ingestion.
BETTERSTACK_SOURCE_TOKEN=REPLACE_ME_logtail_source_token

# --- External APIs ---------------------------------------------------------- #

# Alchemy API key (RPC + NFT API). Free tier supports hackathon scale.
ALCHEMY_API_KEY=REPLACE_ME_alchemy_api_key

# Privy application secret (server-side use in relayer for social-link proof verification).
PRIVY_APP_SECRET=REPLACE_ME_privy_app_secret

# Pinata JWT for IPFS pinning (D-20: smoke-test only in Phase 0; application pinning in Phase 7).
PINATA_JWT=REPLACE_ME_pinata_jwt

# --- Next.js Public Variables (apps/web) ----------------------------------- #
# These are inlined at build time by Next.js and visible client-side.

# Network and chain ID — enforced by EnvConfigSchema in packages/shared.
# mainnet → NEXT_PUBLIC_CHAIN_ID must be 42161.
# sepolia → NEXT_PUBLIC_CHAIN_ID must be 421614.
NEXT_PUBLIC_NETWORK=sepolia
NEXT_PUBLIC_CHAIN_ID=421614

# OG image base URL — constructed from env, never a hardcoded domain (D-12).
# Phase 0–6: default Vercel domain. Phase 7: rebrand to app.callitapp.xyz.
NEXT_PUBLIC_OG_BASE_URL=https://REPLACE_ME.vercel.app

# Relayer URL for client-side calls (mirrors RELAYER_URL; public-safe base URL only).
NEXT_PUBLIC_RELAYER_URL=https://call-it-relayer.fly.dev

# The Graph Decentralized Network subgraph URL.
# Phase 0–6: Subgraph Studio API URL for the arbitrum-sepolia deployment.
# Phase 7: Decentralized Network query URL.
NEXT_PUBLIC_SUBGRAPH_URL=https://api.studio.thegraph.com/query/REPLACE_ME/call-it-sepolia/v0.0.1

# Brand footer text — populated in Phase 7 (D-12 enforcement: never a hardcoded literal).
# Example: "callitapp.xyz · Be right in public."
# Phase 0–6 routes use this env-var, never a hardcoded literal — D-12 enforcement.
NEXT_PUBLIC_BRAND_FOOTER=

# --- Contract deploy (Phase 2 — DeployPhase2.s.sol) ------------------------ #
# Foundry auto-loads a .env from the directory you run `forge` in, OR use already
# `export`ed shell vars. The deploy script reads:
#   DEPLOYER_PRIVATE_KEY     — funded Arbitrum Sepolia key (0x + 64 hex). vm.envUint in the script.
#                              (Note: NOT the same name as the relayer's RELAYER_PRIVATE_KEY.)
#   TREASURY_ADDRESS         — separate EOA/Safe that receives the $10 creation fee.
#                              NEVER the contract address. vm.envAddress in the script.
# foundry.toml [rpc_endpoints]/[etherscan] additionally reference:
#   ARBITRUM_SEPOLIA_RPC_URL — RPC endpoint  (rpc alias: arbitrum_sepolia)
#   ARBITRUM_ONE_RPC_URL     — mainnet RPC   (Phase 7.5; rpc alias: arbitrum_one)
#   ARBISCAN_SEPOLIA_API_KEY — Arbiscan Sepolia key for --verify
#   ARBISCAN_API_KEY         — Arbiscan mainnet key (Phase 7.5)
# Deploy: cd packages/contracts && forge script script/DeployPhase2.s.sol \
#           --rpc-url arbitrum_sepolia --broadcast --verify
DEPLOYER_PRIVATE_KEY=REPLACE_ME_funded_sepolia_deployer_key
TREASURY_ADDRESS=REPLACE_ME_treasury_eoa_or_safe
ARBITRUM_SEPOLIA_RPC_URL=https://REPLACE_ME_arbitrum_sepolia_rpc
ARBITRUM_ONE_RPC_URL=https://REPLACE_ME_arbitrum_one_rpc
ARBISCAN_SEPOLIA_API_KEY=REPLACE_ME_arbiscan_sepolia_key
ARBISCAN_API_KEY=REPLACE_ME_arbiscan_mainnet_key

# --- Subgraph publish (Phase 2 — Plan 02-06) ------------------------------- #
# graph auth $SUBGRAPH_STUDIO_DEPLOY_KEY   (key from the Subgraph Studio dashboard)
SUBGRAPH_STUDIO_DEPLOY_KEY=REPLACE_ME_graph_studio_deploy_key

# --- Relayer DB (Phase 2 — used by db:migrate, drizzle.config.ts) ---------- #
# Fly Postgres connection string. drizzle.config.ts auto-loads this from
# apps/relayer/.env.local or this root .env when not already in the environment.
POSTGRES_URL=postgresql://REPLACE_ME_user:REPLACE_ME_pass@REPLACE_ME_host:5432/call_it
