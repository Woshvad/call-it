# Treat font + image binaries as binary so Git never applies text/EOL normalization
# (which silently corrupted the OG fonts — invalid sfnt signatures — pre-Phase-3).
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wasm binary

# Shell scripts MUST stay LF — a CRLF shebang breaks `/bin/sh` in Linux containers
# (relayer entrypoint.sh runs in node:22-alpine). Force LF regardless of core.autocrlf.
*.sh text eol=lf
