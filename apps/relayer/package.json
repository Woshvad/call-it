    "@types/node-telegram-bot-api": "^0.64.0",
    "drizzle-kit": "^0.31.10",
    "ioredis-mock": "^8.0.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
