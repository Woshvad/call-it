# .dockerignore for the Call It relayer
# Build context: monorepo root — exclude everything not needed for the relayer

# Dependencies (rebuilt during Docker build)
node_modules
apps/relayer/node_modules
packages/shared/node_modules
packages/config/node_modules

# Git history
.git
.gitignore

# Environment files (secrets injected via Fly.io `flyctl secrets set`, D-08)
.env
.env.*
.env.local
.env.*.local

# Test artifacts
apps/relayer/test
apps/relayer/**/*.test.ts
apps/relayer/**/*.test.js
apps/relayer/**/*.spec.ts
apps/relayer/vitest.config.ts
apps/relayer/vitest.config.js

# TypeScript build outputs (rebuilt in Docker stage)
apps/relayer/dist
packages/shared/dist
packages/config/dist

# Unrelated monorepo packages (not needed by the relayer)
apps/web
packages/contracts
packages/subgraph

# Build artifacts
**/.turbo
**/coverage
**/.next

# Editor files
.vscode
.idea
*.swp

# OS files
.DS_Store
Thumbs.db

# Planning/docs (not needed at runtime)
.planning
docs
scripts
